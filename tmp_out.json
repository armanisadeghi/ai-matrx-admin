    },
    {
      "id": "1bf98a62-fa46-4589-b0d4-67bd9afdc535",
      "name": "toolcomp_get_context",
      "category": "internal",
      "description": "Fetch a complete, curated context bundle for a specific tool's UI component. Returns the tool definition (parameters, output_schema), a summary of all component code sections with lengths, condensed test samples (event timelines, argument shapes, output previews), and any open (unresolved) component incidents. Use this as the first call when working on any tool UI component."
    },
