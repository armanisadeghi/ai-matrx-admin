{
  "name": "@matrx/agents",
  "version": "0.1.0",
  "private": true,
  "description": "Unified Redux state + thunks + selectors for the AI Matrx agent system. Framework-agnostic; consumers plug in their own Supabase client, fetch impl, and callback manager via configure().",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./adapters": "./src/adapters/index.ts",
    "./config": "./src/config/index.ts",
    "./types": "./src/types/index.ts"
  },
  "scripts": {
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@reduxjs/toolkit": "^2.0.0",
    "react-redux": "^9.0.0",
    "reselect": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "sideEffects": false
}
