# =============================================================================
# matrx-frontend — Environment configuration
# =============================================================================
# How to use this file:
#   1. Copy to .env.local:    cp .env.example .env.local
#   2. Fill in the REQUIRED section — the app won't run without these.
#   3. Fill in any FEATURE sections for features you actually need to work on.
#      Skipping a feature section just disables that one feature; the app still
#      starts and other features keep working.
#
# Three sections:
#   [1] DEFAULTS         — non-secret config, sane defaults, leave as-is
#   [2] REQUIRED         — must be set or the app cannot serve auth/API routes
#   [3] OPTIONAL FEATURES — each block enables one feature; skip what you don't need
#
# =============================================================================
# QUICK REFERENCE
# =============================================================================
#
# ── REQUIRED to run the app ──────────────────────────────────────────────────
#   NEXT_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
#   SUPABASE_SECRET_KEY
#
# ── Features that BREAK without their env vars ───────────────────────────────
#
#   Email — org invites, password reset, contact form
#       RESEND_API_KEY, EMAIL_FROM, EMAIL_ALLOWED_DOMAINS
#
#   Rate limiting — auth endpoints, public apps, contact form
#       UPSTASH_REDIS_REST_URL, UPSTASH_REDIS_REST_TOKEN
#
#   SMS verification — phone-number verify + outbound SMS
#       TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_VERIFY_SID,
#       TWILIO_MESSAGING_SERVICE_SID, TWILIO_PHONE_NUMBER
#
#   Code sandbox — preview environments, sandbox routes
#       MATRX_ORCHESTRATOR_URL, MATRX_ORCHESTRATOR_API_KEY,
#       MATRX_HOSTED_ORCHESTRATOR_URL, MATRX_HOSTED_ORCHESTRATOR_API_KEY,
#       GITHUB_CLIENT_ID, GITHUB_CLIENT_SECRET,
#       MATRX_SANDBOX_GH_TOKEN, GIT_TOKEN_MATRX_ENGINE_SERVER
#
#   Admin OAuth login — /api/auth/aimatrx-admin + dev-login
#       AIMATRX_SUPABASE_URL, AIMATRX_OAUTH_CLIENT_ID,
#       AIMATRX_OAUTH_CLIENT_SECRET, DEV_LOGIN_TOKEN,
#       AI_ADMIN_USERNAME, AI_ADMIN_PASSWORD, AGENT_API_KEY
#
#   HTML pages CMS — /tests/html-pages
#       NEXT_PUBLIC_SUPABASE_HTML_URL, NEXT_PUBLIC_SUPABASE_HTML_ANON_KEY
#
#   Coolify deployment logs — admin panel only
#       COOLIFY_API_URL, COOLIFY_API_TOKEN
#
#   Slack OAuth — connect Slack workspace
#       SLACK_CLIENT_ID, SLACK_CLIENT_SECRET, NEXT_PUBLIC_SLACK_CLIENT_ID,
#       SLACK_REDIRECT_URL, NEXT_PUBLIC_SLACK_REDIRECT_URL
#
#   Google APIs — PageSpeed test page, Workspace tests
#       NEXT_PUBLIC_GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET,
#       NEXT_PUBLIC_GOOGLE_API_KEY
#
#   Stock images — Unsplash gallery picker
#       UNSPLASH_ACCESS_KEY (server-only — proxied through /api/unsplash)
#
#   News headlines page
#       NEWS_API_KEY, NEXT_PUBLIC_NEWS_API_KEY
#
#   Voice assistant + debate — chat backbone
#       GROQ_API_KEY
#
#   Speech-to-text + speak endpoints
#       DEEPGRAM_API_KEY
#
#   Cartesia TTS — flash-cards audio + voice-assistant TTS
#       CARTESIA_API_KEY, NEXT_PUBLIC_CARTESIA_API_KEY
#
#   Wake-word — voice assistant trigger phrase
#       NEXT_PUBLIC_PICOVOICE_ACCESS_KEY
#
#   Alt LLM providers — flash-cards AI chat, voice assistant fallbacks
#       OPENAI_API_KEY, NEXT_PUBLIC_OPENAI_API_KEY, ANTHROPIC_API_KEY
#
# =============================================================================


# =============================================================================
# [1] DEFAULTS — non-secret config (safe to commit, just leave as-is)
# =============================================================================

# --- App behavior ---
NEXT_PUBLIC_ENV=local
NEXT_PUBLIC_ENABLE_DEBUG=false

# --- Logging ---
LOG_LEVEL=info               # server log level: debug | info | warn | error
CONSOLE_LOG_LEVEL=none       # browser console verbosity: none | normal | verbose
DETAIL_LEVEL=standard        # log detail: minimal | standard | verbose

# --- URLs (public site + Python backend tiers) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_HTML_SITE_URL=https://mymatrx.com

# Python backend (matrx-engine). The "BACKEND_URL" is the active one;
# the others are picked by the share-page tier resolver.
NEXT_PUBLIC_BACKEND_URL=https://server.app.matrxserver.com
NEXT_PUBLIC_BACKEND_URL_PROD=https://server.app.matrxserver.com
NEXT_PUBLIC_BACKEND_URL_DEV=https://dev.server.app.matrxserver.com
NEXT_PUBLIC_BACKEND_URL_STAGING=https://staging.server.app.matrxserver.com
NEXT_PUBLIC_BACKEND_URL_LOCAL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL_GPU=https://80.188.223.202


# =============================================================================
# [2] REQUIRED — app won't start / auth won't work without these
# =============================================================================

# --- Supabase (primary auth + database) ---
# All API routes and the auth flow depend on these.
# Use the new "sb_publishable_*" / "sb_secret_*" keys from the Supabase dashboard.
# (The legacy JWT-based anon / service_role keys are deprecated.)
# Docs: https://supabase.com/docs/guides/getting-started/api-keys
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=    # client-safe — sb_publishable_*
SUPABASE_SECRET_KEY=                     # server-only — sb_secret_* — used by admin API routes


# =============================================================================
# [3] OPTIONAL FEATURES — fill in only what you'll actually work on
# =============================================================================

# -----------------------------------------------------------------------------
# Email (Resend)  ── feature: organization invites, password resets, contact form
# Without it: any code path that sends email throws at first call.
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=AI Matrx <noreply@aimatrx.com>
EMAIL_ALLOWED_DOMAINS=aimatrx.com,updates.aimatrx.com

# -----------------------------------------------------------------------------
# Rate limiting (Upstash Redis)  ── feature: throttling on auth, public apps, contact form
# Without it: any rate-limited endpoint throws on first call.
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# SMS verification (Twilio)  ── feature: phone-number verification + outbound SMS
# Without it: SMS verify endpoints fail.
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=
TWILIO_SKIP_VALIDATION=true        # dev only — bypasses webhook signature check

# -----------------------------------------------------------------------------
# Sandbox orchestrator (matrx sandbox feature)
# Without it: code-sandbox / preview-environment routes return 500.
# -----------------------------------------------------------------------------
MATRX_ORCHESTRATOR_URL=
MATRX_ORCHESTRATOR_API_KEY=
MATRX_HOSTED_ORCHESTRATOR_URL=
MATRX_HOSTED_ORCHESTRATOR_API_KEY=

# Sandbox GitHub creds (workspace clone + deploy)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MATRX_SANDBOX_GH_TOKEN=
GIT_TOKEN_MATRX_ENGINE_SERVER=

# -----------------------------------------------------------------------------
# AI Matrx OAuth admin login  ── feature: /api/auth/aimatrx-admin login flow
# Without it: admin OAuth login route fails.
# -----------------------------------------------------------------------------
AIMATRX_SUPABASE_URL=https://db.matrxserver.com
AIMATRX_OAUTH_CLIENT_ID=
AIMATRX_OAUTH_CLIENT_SECRET=
DEV_LOGIN_TOKEN=                   # used by /api/auth/dev-login

# Dev admin credentials (shortcut for the dev-login endpoint)
AI_ADMIN_USERNAME=admin@admin.com
AI_ADMIN_PASSWORD=

# Agent / external MCP API access
AGENT_API_KEY=

# -----------------------------------------------------------------------------
# HTML pages CMS (separate Supabase project)  ── feature: /tests/html-pages
# Without it: HTML pages CMS routes return errors.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_HTML_URL=
NEXT_PUBLIC_SUPABASE_HTML_ANON_KEY=

# -----------------------------------------------------------------------------
# Coolify  ── feature: admin panel deployment-log viewer
# Without it: only the admin coolify-logs page is broken.
# -----------------------------------------------------------------------------
COOLIFY_API_URL=
COOLIFY_API_TOKEN=

# -----------------------------------------------------------------------------
# Slack OAuth  ── feature: connect Slack workspace
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SLACK_CLIENT_ID=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
NEXT_PUBLIC_SLACK_REDIRECT_URL=http://localhost:3000
SLACK_REDIRECT_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Google APIs  ── feature: PageSpeed test page + Google Workspace tests
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# Image / news search  ── feature: stock-image picker + top headlines
# -----------------------------------------------------------------------------
# Unsplash gallery — server-side only (proxied through /api/unsplash)
UNSPLASH_ACCESS_KEY=

# News headlines
NEWS_API_KEY=
NEXT_PUBLIC_NEWS_API_KEY=

# -----------------------------------------------------------------------------
# Voice / AI features (LEGACY — most LLM work has moved to the Python server)
# These are still wired into a few in-app demos and the flash-cards AI chat.
# -----------------------------------------------------------------------------

# Voice assistant + debate page (Groq is the default chat provider)
GROQ_API_KEY=

# Speech-to-text + speak endpoints
DEEPGRAM_API_KEY=

# Cartesia TTS — used by flash-cards audio + voice-assistant TTS
CARTESIA_API_KEY=
NEXT_PUBLIC_CARTESIA_API_KEY=

# Wake-word detection in the voice assistant
NEXT_PUBLIC_PICOVOICE_ACCESS_KEY=

# Optional alt providers for the voice assistant + flash-cards chat
OPENAI_API_KEY=
NEXT_PUBLIC_OPENAI_API_KEY=
ANTHROPIC_API_KEY=
