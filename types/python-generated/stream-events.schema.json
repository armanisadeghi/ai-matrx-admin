{
  "ChunkPayload": {
    "additionalProperties": false,
    "description": "Streaming text chunk — emitted as the LLM generates tokens.",
    "properties": {
      "text": {
        "title": "Text",
        "type": "string"
      }
    },
    "required": [
      "text"
    ],
    "title": "ChunkPayload",
    "type": "object"
  },
  "StatusUpdatePayload": {
    "additionalProperties": false,
    "description": "Human-readable status update. system_message is for logs; user_message for UI.",
    "properties": {
      "status": {
        "title": "Status",
        "type": "string"
      },
      "system_message": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "System Message"
      },
      "user_message": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "User Message"
      },
      "metadata": {
        "anyOf": [
          {
            "additionalProperties": true,
            "type": "object"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Metadata"
      }
    },
    "required": [
      "status"
    ],
    "title": "StatusUpdatePayload",
    "type": "object"
  },
  "DataPayload": {
    "additionalProperties": true,
    "description": "Arbitrary structured data payload. Extra fields allowed — use for service-specific data.",
    "properties": {},
    "title": "DataPayload",
    "type": "object"
  },
  "CompletionPayload": {
    "additionalProperties": false,
    "description": "Final completion event. Sent once per request, immediately before END.",
    "properties": {
      "status": {
        "default": "complete",
        "enum": [
          "complete",
          "failed",
          "max_iterations_exceeded"
        ],
        "title": "Status",
        "type": "string"
      },
      "output": {
        "default": null,
        "title": "Output"
      },
      "iterations": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Iterations"
      },
      "total_usage": {
        "anyOf": [
          {
            "additionalProperties": true,
            "type": "object"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Total Usage"
      },
      "timing_stats": {
        "anyOf": [
          {
            "additionalProperties": true,
            "type": "object"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Timing Stats"
      },
      "tool_call_stats": {
        "anyOf": [
          {
            "additionalProperties": true,
            "type": "object"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Tool Call Stats"
      },
      "finish_reason": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Finish Reason"
      },
      "metadata": {
        "anyOf": [
          {
            "additionalProperties": true,
            "type": "object"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Metadata"
      }
    },
    "title": "CompletionPayload",
    "type": "object"
  },
  "ErrorPayload": {
    "additionalProperties": false,
    "description": "Structured error. user_message is safe to display to end users.",
    "properties": {
      "error_type": {
        "title": "Error Type",
        "type": "string"
      },
      "message": {
        "title": "Message",
        "type": "string"
      },
      "user_message": {
        "default": "Sorry. An error occurred.",
        "title": "User Message",
        "type": "string"
      },
      "code": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Code"
      },
      "details": {
        "anyOf": [
          {
            "additionalProperties": true,
            "type": "object"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Details"
      }
    },
    "required": [
      "error_type",
      "message"
    ],
    "title": "ErrorPayload",
    "type": "object"
  },
  "ToolEventPayload": {
    "additionalProperties": false,
    "description": "Tool lifecycle event. Emitted by the tool executor during tool calls.",
    "properties": {
      "event": {
        "enum": [
          "tool_started",
          "tool_progress",
          "tool_step",
          "tool_result_preview",
          "tool_completed",
          "tool_error",
          "tool_delegated"
        ],
        "title": "Event",
        "type": "string"
      },
      "call_id": {
        "title": "Call Id",
        "type": "string"
      },
      "tool_name": {
        "title": "Tool Name",
        "type": "string"
      },
      "timestamp": {
        "title": "Timestamp",
        "type": "number"
      },
      "message": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Message"
      },
      "show_spinner": {
        "default": true,
        "title": "Show Spinner",
        "type": "boolean"
      },
      "data": {
        "additionalProperties": true,
        "title": "Data",
        "type": "object"
      }
    },
    "required": [
      "event",
      "call_id",
      "tool_name"
    ],
    "title": "ToolEventPayload",
    "type": "object"
  },
  "BrokerPayload": {
    "additionalProperties": false,
    "description": "Cross-service value delivery. broker_id identifies the subscriber.",
    "properties": {
      "broker_id": {
        "title": "Broker Id",
        "type": "string"
      },
      "value": {
        "title": "Value"
      },
      "source": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Source"
      },
      "source_id": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Source Id"
      }
    },
    "required": [
      "broker_id",
      "value"
    ],
    "title": "BrokerPayload",
    "type": "object"
  },
  "HeartbeatPayload": {
    "additionalProperties": false,
    "description": "Keepalive ping sent on idle connections to prevent proxy timeouts.",
    "properties": {
      "timestamp": {
        "title": "Timestamp",
        "type": "number"
      }
    },
    "title": "HeartbeatPayload",
    "type": "object"
  },
  "EndPayload": {
    "additionalProperties": false,
    "description": "Stream termination signal. Always the last event in a stream.",
    "properties": {
      "reason": {
        "default": "complete",
        "title": "Reason",
        "type": "string"
      }
    },
    "title": "EndPayload",
    "type": "object"
  },
  "ContentBlockPayload": {
    "additionalProperties": false,
    "description": "A structured content block emitted by StreamBlockProcessor.\n\nSent for every block lifecycle change: open (streaming), incremental\nupdate, and close (complete/error). The `content` field carries raw\ntext for Text Channel blocks; the `data` field carries parsed structured\ndata for Block Channel blocks. See streaming-constitution.md for the\nfull contract.\n\nNote: Fields are camelCase on the wire (matching ContentBlockEvent alias_generator=to_camel).",
    "properties": {
      "blockId": {
        "description": "Stable ID for this block, e.g. 'blk_0'",
        "title": "Blockid",
        "type": "string"
      },
      "blockIndex": {
        "description": "Ordering position among all blocks in the message",
        "title": "Blockindex",
        "type": "integer"
      },
      "type": {
        "description": "Block type key, e.g. 'text', 'timeline', 'quiz'",
        "title": "Type",
        "type": "string"
      },
      "status": {
        "description": "Block lifecycle status",
        "enum": [
          "streaming",
          "complete",
          "error"
        ],
        "title": "Status",
        "type": "string"
      },
      "content": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Raw text content (Text Channel blocks)",
        "title": "Content"
      },
      "data": {
        "anyOf": [
          {
            "additionalProperties": true,
            "type": "object"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Parsed structured data (Block Channel blocks)",
        "title": "Data"
      },
      "metadata": {
        "additionalProperties": true,
        "description": "Block metadata (language, isComplete, etc.)",
        "title": "Metadata",
        "type": "object"
      }
    },
    "required": [
      "blockId",
      "blockIndex",
      "type",
      "status"
    ],
    "title": "ContentBlockPayload",
    "type": "object"
  },
  "StreamEvent": {
    "$defs": {
      "EventType": {
        "enum": [
          "chunk",
          "status_update",
          "data",
          "completion",
          "error",
          "tool_event",
          "broker",
          "heartbeat",
          "end",
          "content_block"
        ],
        "title": "EventType",
        "type": "string"
      }
    },
    "additionalProperties": false,
    "properties": {
      "event": {
        "$ref": "#/$defs/EventType"
      },
      "data": {
        "additionalProperties": true,
        "title": "Data",
        "type": "object"
      }
    },
    "required": [
      "event",
      "data"
    ],
    "title": "StreamEvent",
    "type": "object"
  },
  "EventType": {
    "enum": [
      "chunk",
      "status_update",
      "data",
      "completion",
      "error",
      "tool_event",
      "broker",
      "heartbeat",
      "end",
      "content_block"
    ]
  }
}
